{
    "name": "yangusik/symfony-spawn",
    "description": "Symfony adapter for PHP TrueAsync — async HTTP server with coroutine-per-request isolation",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": "^8.6",
        "symfony/framework-bundle": "^7.0|^8.0",
        "symfony/runtime": "^7.0|^8.0",
        "symfony/security-core": "^7.0|^8.0",
        "ext-pcntl": "*",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "symfony/http-client": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Spawn\\Symfony\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Spawn\\Symfony\\Tests\\": "tests/"
        }
    },
    "extra": {
        "runtime": {
            "class": "Spawn\\Symfony\\Runtime\\TrueAsyncRuntime"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
